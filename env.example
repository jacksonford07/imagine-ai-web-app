# Copy to .env.local and fill in.

# Bot read API (Render public URL of imagine-ai-bot). No trailing slash.
BOT_API_URL=https://imagine-ai-bot.onrender.com
# Must equal the bot's INTERNAL_CRON_SECRET.
BOT_INTERNAL_SECRET=

# Sign-in access is resolved from the bot DB (/internal/admin/users) — no
# email allowlist env. The bot seeds the root admin.

# NextAuth / Auth.js
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Full origin of this app (Vercel URL in prod, http://localhost:3000 in dev).
NEXTAUTH_URL=http://localhost:3000

# Google OAuth client (console.cloud.google.com -> Credentials -> OAuth client).
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
